#! /usr/bin/env python3

import os
import re
import sys
import sqlite3
import hashlib
import urllib.request
import subprocess
import uuid
from datetime import datetime


################ CONFIG ################

DB = os.path.expanduser("/Library/Application Support/fid/fid.db")
CACHE_DIR = os.path.expanduser("/Library/Application Support/fid/cache")

KEEP_CACHE = True

BASE62 = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz"

########################################


############ INIT ######################


def ensure_dirs():

    os.makedirs(os.path.dirname(DB), exist_ok=True)
    os.makedirs(CACHE_DIR, exist_ok=True)

def db():

    ensure_dirs()

    conn = sqlite3.connect(DB)
    c = conn.cursor()

    c.execute("""
    CREATE TABLE IF NOT EXISTS files(
        md5_hex TEXT PRIMARY KEY,
        md5_base62 TEXT UNIQUE,
        created TEXT,
        name TEXT,
        extension TEXT
    )
    """)

    c.execute("""
    CREATE TABLE IF NOT EXISTS locations(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        md5_hex TEXT,
        path TEXT,
        added TEXT
    )
    """)

    c.execute("""
    CREATE TABLE IF NOT EXISTS metadata(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        md5_hex TEXT,
        key TEXT,
        value TEXT
    )
    """)

    conn.commit()

    return conn


############ HASH ######################


def md5_file(path):

    h = hashlib.md5()

    with open(path, "rb") as f:

        for chunk in iter(lambda: f.read(8192), b""):

            h.update(chunk)

    return h.digest()


def base62_encode(data):

    n = int.from_bytes(data, "big")

    s = ""

    while n:

        n, r = divmod(n, 62)

        s = BASE62[r] + s

    return s.zfill(22)


def base62_decode(s):

    n = 0

    for c in s:

        n = n * 62 + BASE62.index(c)

    return n.to_bytes(16, "big")


############ PATH HANDLING #############


def normalize_path(path):

    if "://" in path:

        return path

    if path.startswith("fid://"):

        return path

    return os.path.abspath(path)


def split_path(path):

    if "://" in path:

        scheme, rest = path.split("://", 1)

        return scheme, rest

    return "local", path


############ EXPANSION #################

def expand_paths(paths):
    """Expand folders into files and return all file paths."""
    expanded = []
    for path in paths:
        norm_path = normalize_path(path)
        if os.path.isdir(norm_path):
            # Add all files in directory (non-recursive)
            try:
                for item in os.listdir(norm_path):
                    item_path = os.path.join(norm_path, item)
                    if os.path.isfile(item_path):
                        expanded.append(item_path)
            except:
                print(f"cannot read directory: {norm_path}", file=sys.stderr)
        else:
            expanded.append(norm_path)
    return expanded

############ LOOKUP ####################


def lookup(conn, prefix):

    return conn.execute(
        "SELECT md5_hex, md5_base62 FROM files WHERE md5_base62 LIKE ?",
        (prefix + "%",)
    ).fetchall()


############ CACHE #####################


def purge_cache():

    if not os.path.exists(CACHE_DIR):
        return

    for f in os.listdir(CACHE_DIR):

        try:
            os.remove(os.path.join(CACHE_DIR, f))
        except:
            pass

    print("cache cleared", file=sys.stderr)


############ DOWNLOAD ##################


def download_temp(prefix, source):
    print(prefix,source)

    basename = re.split(r"[/\\\\=]", source)[-1]
    
    tmp=os.path.join(CACHE_DIR, basename + '.' + str(uuid.uuid4()))
 #   tmp = os.path.join(CACHE_DIR, name + "_" + str(uuid.uuid4()) + ext)
 
    try:

        if prefix in ("url", "http"):

            urllib.request.urlretrieve(f'http://{source}', tmp)

        elif prefix == "https":
            urllib.request.urlretrieve(f'https://{source}', tmp)

        elif prefix == "ftp":

            urllib.request.urlretrieve(f'ftp://{source}', tmp)

        elif prefix == "sftp":

            subprocess.run(["scp", source, tmp], check=True)

        else:

            return None
        

        return tmp

    except:
        print("download failed", file=sys.stderr)
        return None


############ SPOTLIGHT ##################

import subprocess

def write_spotlight_metadata(path, fid):

    try:
        subprocess.run([
            "xattr",
            "-w",
            "com.apple.metadata:kMDItemWhereFroms",
            f"fid://{fid}",
            path
        ], check=False)
    except:
        pass


############ REGISTER ##################


def register_single(path):
    """Register a single file and return its fid, or None on failure."""
    conn = db()

    path = normalize_path(path)

    prefix, value = split_path(path)

    if prefix == "local":

        filepath = value
        basename = os.path.basename(value)

    else:

        tmp = download_temp(prefix, value)

        if not tmp:

            return None

        filepath = tmp
        basename = re.split(r"[/\\\\=]", value)[-1]

    if not os.path.exists(filepath):

        print("file missing", file=sys.stderr)

        return None

    md5 = md5_file(filepath)

    md5_hex = md5.hex()

    md5_b62 = base62_encode(md5)

    # Extract name and extension from filepath

    if '.' in basename:
        name, extension = basename.split('.', 1)
    else:
        extension = ''

    if prefix != "local":
        write_spotlight_metadata(filepath, md5_b62)

    cur = conn.cursor()

    row = cur.execute(
        "SELECT md5_base62 FROM files WHERE md5_hex=?",
        (md5_hex,)
    ).fetchone()

    if row:

        if prefix != "local":

            os.remove(filepath)

    else:

        cur.execute(
            "INSERT INTO files VALUES (?,?,?,?,?)",
            (md5_hex, md5_b62, datetime.now(), name, extension)
        )


        if prefix != "local":

            #the final filepath and name will be CACHE_DIR/md5_b62/name.ext
            cache_path = os.path.join(CACHE_DIR, md5_b62, basename)

            os.makedirs(os.path.join(CACHE_DIR, md5_b62), exist_ok=True)
            os.rename(filepath, cache_path)

            cur.execute(
                "SELECT 1 FROM locations WHERE md5_hex=? AND path=?",
                (md5_hex, cache_path)
            )
            if not cur.fetchone():
                cur.execute(
                    "INSERT INTO locations VALUES(NULL,?,?,?)",
                    (md5_hex, cache_path, datetime.now())
                )

    cur.execute(
        "SELECT 1 FROM locations WHERE md5_hex=? AND path=?",
        (md5_hex, path)
    )
    if not cur.fetchone():
        cur.execute(
            "INSERT INTO locations VALUES(NULL,?,?,?)",
            (md5_hex, path, datetime.now())
        )

    conn.commit()

    return md5_b62


def register(paths):
    """Register one or more files/directories."""
    expanded = expand_paths(paths)
    for path in expanded:
        fid = register_single(path)
        if fid:
            print(fid)


############ RESOLVE ###################


def resolve_single(prefix, domain=None):
    """Resolve a single fid prefix to a path. Returns None if not found.
    
    If domain is provided, only return paths containing the domain string.
    """
    conn = db()

    if not KEEP_CACHE:

        purge_cache()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique", file=sys.stderr)

        return None

    md5_hex, md5_b62 = matches[0]

    cur = conn.cursor()

    rows = cur.execute(
        "SELECT id,path FROM locations WHERE md5_hex=?",
        (md5_hex,)
    ).fetchall()

    remote = []

    for loc_id, path in rows:

        pfx, val = split_path(path)

        if pfx == "local":

            if os.path.exists(val):
                # Check domain filter
                if domain is None or domain in val:
                    return val

            else:

                cur.execute(
                    "DELETE FROM locations WHERE id=?",
                    (loc_id,)
                )

        else:

            remote.append((loc_id, pfx, val))

    conn.commit()

    for loc_id, pfx, val in remote:

        tmp = download_temp(pfx, val)
        if not tmp:
            continue

        if md5_file(tmp).hex() != md5_hex:

            os.remove(tmp)

            conn.execute(
                "DELETE FROM locations WHERE id=?",
                (loc_id,)
            )

            continue

        basename = re.split(r"[/\\\\=]", val)[-1]
        cache_path = os.path.join(CACHE_DIR, md5_b62, basename)

        os.makedirs(os.path.join(CACHE_DIR, md5_b62), exist_ok=True)
        os.rename(tmp, cache_path)

        conn.execute(
            "INSERT INTO locations VALUES(NULL,?,?,?)",
            (md5_hex, cache_path, datetime.now())
        )

        conn.commit()

        return cache_path

    conn.commit()

    print("no valid locations found", file=sys.stderr)
    return None

############ ADD ####################


def add_single(fid_prefix, path):
    """Add a path to an existing fid. Returns True on success, False on failure."""
    conn = db()
    
    path = normalize_path(path)
    
    # Look up the fid (requires full 22-char fid or unique prefix)
    matches = lookup(conn, fid_prefix)
    
    if len(matches) == 0:
        print("fid not found", file=sys.stderr)
        return False
    
    if len(matches) != 1:
        print("fid prefix not unique", file=sys.stderr)
        return False
    
    md5_hex, md5_b62 = matches[0]
    
    cur = conn.cursor()
    
    # Check if this path is already registered for this fid
    cur.execute(
        "SELECT 1 FROM locations WHERE md5_hex=? AND path=?",
        (md5_hex, path)
    )
    if cur.fetchone():
        print("path already registered for this fid", file=sys.stderr)
        return False
    
    # Add the location
    cur.execute(
        "INSERT INTO locations VALUES(NULL,?,?,?)",
        (md5_hex, path, datetime.now())
    )
    
    conn.commit()
    
    # Write spotlight metadata
    write_spotlight_metadata(path, md5_b62)
    
    return True


def add(args):
    """Add one or more paths to an existing fid.
    
    Usage: fid add <fid> <path> [<path> ...]
    """
    if len(args) < 2:
        print("usage: fid add <fid> <path> [<path> ...]", file=sys.stderr)
        return
    
    fid_prefix = args[0]
    paths = args[1:]
    
    expanded = expand_paths(paths)
    
    for path in expanded:
        if add_single(fid_prefix, path):
            print(path)

def resolve(prefixes, domain=None):
    """Resolve one or more fid prefixes to paths.
    
    If domain is provided, only print paths containing the domain string.
    """
    for prefix in prefixes:
        path = resolve_single(prefix.replace("fid://", ""), domain=domain)
        if path:
            print(path)


############ ID #######################

def fid_id_single(path):
    """Get the fid for a single file. Returns None if not found."""
    conn = db()

    path = normalize_path(path)

    cur = conn.cursor()

    row = cur.execute(
        "SELECT md5_hex FROM locations WHERE path=?",
        (path,)
    ).fetchone()

    if row:

        md5_hex = row[0]

        md5_b62 = cur.execute(
            "SELECT md5_base62 FROM files WHERE md5_hex=?",
            (md5_hex,)
        ).fetchone()[0]

        return md5_b62

    fid = register_single(path)
    return fid


def fid_id(paths):
    """Get fids for one or more files."""
    expanded = expand_paths(paths)
    for path in expanded:
        fid = fid_id_single(path)
        if fid:
            print(fid)

############ VERIFY ####################


def verify_single(prefix, bysize=False):
    """Verify a single fid prefix.
    
    If bysize=True, verify by file size instead of MD5 checksum (faster).
    """
    conn = db()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique", file=sys.stderr)

        return

    md5_hex = matches[0][0]
    
    reference_size = None

    for loc_id, path in conn.execute(
        "SELECT id,path FROM locations WHERE md5_hex=?",
        (md5_hex,)
    ):

        pfx, val = split_path(path)

        if pfx != "local":
            print("REMOTE - not verified", val)
            continue

        if not os.path.exists(val):

            print("MISSING", val)

            continue

        if bysize:
            # Verify by file size
            try:
                file_size = os.path.getsize(val)
                
                # Use first file's size as reference
                if reference_size is None:
                    reference_size = file_size
                
                if file_size == reference_size:
                    print("OK", val)
                else:
                    print("MISMATCH", val)
            except Exception as e:
                print("ERROR", val, str(e))
        else:
            # Verify by MD5 checksum
            if md5_file(val).hex() == md5_hex:

                print("OK", val)

            else:

                print("MISMATCH", val)


def verify(prefixes, bysize=False):
    """Verify one or more fid prefixes."""
    for prefix in prefixes:
        verify_single(prefix.replace("fid://", ""), bysize=bysize)


############ METADATA ##################


def meta_set(prefix, key, value):

    conn = db()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique", file=sys.stderr)

        return

    md5_hex = matches[0][0]

    conn.execute(
        "DELETE FROM metadata WHERE md5_hex=? AND key=?",
        (md5_hex, key)
    )

    conn.execute(
        "INSERT INTO metadata VALUES(NULL,?,?,?)",
        (md5_hex, key, value)
    )

    conn.commit()


def meta_get(prefix):

    conn = db()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique", file=sys.stderr)

        return

    md5_hex = matches[0][0]

    for key, value in conn.execute(
        "SELECT key,value FROM metadata WHERE md5_hex=?",
        (md5_hex,)
    ):

        print(f"{key}={value}")


def meta_rm(prefix, key):

    conn = db()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique", file=sys.stderr)

        return

    md5_hex = matches[0][0]

    conn.execute(
        "DELETE FROM metadata WHERE md5_hex=? AND key=?",
        (md5_hex, key)
    )

    conn.commit()


############ FIND ######################


def find(expr):

    key, value = expr.split("=")

    conn = db()

    rows = conn.execute(
        """
        SELECT md5_base62
        FROM metadata
        JOIN files USING(md5_hex)
        WHERE key=? AND value=?
        """,
        (key, value)
    ).fetchall()

    for row in rows:

        print(row[0])


############ LIST ######################


def yaml_out(project=None):
    """Output all registered files in YAML format with metadata.
    
    If project is provided, only show fids that have matching project metadata.
    """
    conn = db()
    cur = conn.cursor()

    files = cur.execute(
        "SELECT md5_hex, md5_base62, name, extension FROM files ORDER BY md5_base62"
    ).fetchall()

    output_lines = []
    
    for md5_hex, md5_b62, name, extension in files:

        locations = cur.execute(
            "SELECT path FROM locations WHERE md5_hex=?",
            (md5_hex,)
        ).fetchall()

        # Get metadata for this file
        metadata = cur.execute(
            "SELECT key, value FROM metadata WHERE md5_hex=?",
            (md5_hex,)
        ).fetchall()

        metadata_dict = dict(metadata) if metadata else {}

        # Filter by project if specified
        if project is not None:
            if metadata_dict.get("project") != project:
                continue

        if locations:
            # Start YAML entry with fid as key
            output_lines.append(f"{md5_b62}:")
            output_lines.append(f"  md5_hex: {md5_hex}")
            output_lines.append(f"  name: {name}")
            if extension:
                output_lines.append(f"  extension: {extension}")
            
            # Add locations
            output_lines.append("  locations:")
            for (path,) in locations:
                output_lines.append(f"    - {path}")
            
            # Add metadata if present
            if metadata_dict:
                output_lines.append("  metadata:")
                for key, value in sorted(metadata_dict.items()):
                    output_lines.append(f"    {key}: {value}")
            
            output_lines.append("")  # blank line between entries
    
    # Print all output
    if output_lines:
        print("\n".join(output_lines))


############ CLEAN ######################


def clean():
    """Remove all fids without any locations."""
    conn = db()
    cur = conn.cursor()

    # Find all fids with no locations
    orphaned = cur.execute(
        """
        SELECT md5_hex, md5_base62 FROM files
        WHERE md5_hex NOT IN (SELECT md5_hex FROM locations)
        """
    ).fetchall()

    if not orphaned:
        print("no orphaned fids found", file=sys.stderr)
        return

    count = 0
    for md5_hex, md5_b62 in orphaned:
        # Delete metadata for this fid
        cur.execute("DELETE FROM metadata WHERE md5_hex=?", (md5_hex,))
        # Delete the file entry
        cur.execute("DELETE FROM files WHERE md5_hex=?", (md5_hex,))
        count += 1

    conn.commit()
    print(f"removed {count} orphaned fid(s)", file=sys.stderr)

############ CLOUDPULL #################


def cloudpull(url):
    """Download CSV from URL, import into fid database, then delete the file.
    
    Usage: fid cloudpull <url>
    URL can start with http://, https://, ftp://, or sftp://
    """
    # Parse the URL to extract scheme and source
    if "://" not in url:
        print("invalid url format", file=sys.stderr)
        return
    
    prefix, source = url.split("://", 1)
    
    # Download the file
    tmp = download_temp(prefix, source)
    
    if not tmp:
        print("cloudpull failed", file=sys.stderr)
        return
    
    try:
        # Import the CSV file
        read(tmp)
    finally:
        # Delete the temporary file
        try:
            os.remove(tmp)
        except:
            pass


############ CSV I/O ####################


def parse_csv_line(line):
    """Parse a CSV line and identify md5_b62, md5_hex, and path columns.
    
    Returns tuple (md5_b62, md5_hex, path).
    Columns can be in any order and md5_b62/md5_hex can be skipped.
    Validates format by length and character set.
    """
    parts = [p.strip() for p in line.split(",")]
    
    md5_b62 = None
    md5_hex = None
    path = None
    
    for part in parts:
        if not part:
            continue
        
        # Check for explicit prefixes first
        if part.startswith("fid://"):
            clean = part[6:]
            if len(clean) == 22 and all(c in BASE62 for c in clean):
                if md5_b62 is None:
                    md5_b62 = clean
            continue
        
        if part.startswith("md5://"):
            clean = part[6:]
            if len(clean) == 32 and all(c in "0123456789abcdefABCDEF" for c in clean):
                if md5_hex is None:
                    md5_hex = clean.lower()
            continue
        
        # Try to identify by format (no prefix)
        # 22 base62 chars -> fid
        if len(part) == 22 and all(c in BASE62 for c in part):
            if md5_b62 is None:
                md5_b62 = part
                continue
        
        # 32 hex chars -> md5
        if len(part) == 32 and all(c in "0123456789abcdefABCDEF" for c in part):
            if md5_hex is None:
                md5_hex = part.lower()
                continue
        
        # Otherwise -> path
        if path is None:
            path = part
    
    return md5_b62, md5_hex, path


def write(output_file=None, domain=None):
    """Write all registered files to CSV format (fid, md5, path).
    
    Output format: fid://base62,md5://hex,path
    If domain is provided, only write locations containing the domain string.
    If output_file is None, writes to stdout.
    """
    conn = db()
    cur = conn.cursor()
    
    files = cur.execute(
        "SELECT md5_hex, md5_base62 FROM files ORDER BY md5_base62"
    ).fetchall()
    
    lines = []
    for md5_hex, md5_b62 in files:
        locations = cur.execute(
            "SELECT path FROM locations WHERE md5_hex=?",
            (md5_hex,)
        ).fetchall()
        
        # Filter locations by domain if provided
        if domain is not None:
            locations = [(path,) for (path,) in locations if domain in path]
        
        for (path,) in locations:
            line = f"fid://{md5_b62},md5://{md5_hex},{path}"
            lines.append(line)
    
    output = "\n".join(lines)
    if lines:
        output += "\n"
    
    if output_file:
        try:
            with open(output_file, "w") as f:
                f.write(output)
        except Exception as e:
            print(f"cannot write file: {e}", file=sys.stderr)
    else:
        print(output, end="")


def read(input_file=None):
    """Read CSV file (fid, md5, path) and insert directly into database.
    
    CSV format: fid://base62,md5://hex,path (columns can be in any order)
    - Prefixes (fid://, md5://) are optional
    - Either md5_b62 or md5_hex can be skipped (the other is calculated)
    - No validation performed; entries inserted as-is
    - Empty lines and lines starting with # are skipped
    If input_file is None, reads from stdin.
    """
    conn = db()
    cur = conn.cursor()
    
    if input_file:
        try:
            with open(input_file, "r") as f:
                lines = f.readlines()
        except Exception as e:
            print(f"cannot read file: {e}", file=sys.stderr)
            return
    else:
        lines = sys.stdin.readlines()
    
    for line_num, line in enumerate(lines, 1):
        line = line.strip()
        
        # Skip empty lines and comments
        if not line or line.startswith("#"):
            continue
        
        # Parse the line
        md5_b62, md5_hex, path = parse_csv_line(line)
        
        # Require at least path
        if not path:
            print(f"line {line_num}: no valid path found", file=sys.stderr)
            continue
        
        # Calculate missing hash if needed
        if md5_b62 and not md5_hex:
            # Decode md5_hex from md5_b62
            try:
                md5_bytes = base62_decode(md5_b62)
                md5_hex = md5_bytes.hex()
            except (ValueError, IndexError):
                print(f"line {line_num}: invalid fid format", file=sys.stderr)
                continue
        
        if md5_hex and not md5_b62:
            # Calculate md5_b62 from md5_hex
            try:
                md5_bytes = bytes.fromhex(md5_hex)
                md5_b62 = base62_encode(md5_bytes)
            except ValueError:
                print(f"line {line_num}: invalid md5 hex format", file=sys.stderr)
                continue
        
        # If only path provided, register it as a new file
        if not md5_b62 and not md5_hex:
            fid = register_single(path)
            if fid:
                print(fid)
            else:
                print(f"line {line_num}: failed to register {path}", file=sys.stderr)
            continue
        
        # Extract name and extension from path
        basename = re.split(r"[/\\\\=]", path)[-1] #check if this works
        if '.' in basename:
            name, extension = basename.split('.', 1)
        else:
            extension = ''
        
        # Insert into database directly (upsert on md5_hex)
        try:
            cur.execute(
                "INSERT OR IGNORE INTO files VALUES (?,?,?,?,?)",
                (md5_hex, md5_b62, datetime.now(), name, extension)
            )
            
            # Insert location
            cur.execute(
                "SELECT 1 FROM locations WHERE md5_hex=? AND path=?",
                (md5_hex, path)
            )
            if not cur.fetchone():
                cur.execute(
                    "INSERT INTO locations VALUES(NULL,?,?,?)",
                    (md5_hex, path, datetime.now())
                )
            
            conn.commit()
            print(md5_b62)
        except Exception as e:
            print(f"line {line_num}: database error: {e}", file=sys.stderr)

############ CLI #######################


def main():

    if len(sys.argv) < 2:

        print("usage: fid <command>")

        return

    cmd = sys.argv[1]

    if cmd == "register":

        if len(sys.argv) < 3:
            print("usage: fid register <path> [<path> ...]", file=sys.stderr)
            return
        register(sys.argv[2:])

    elif cmd == "resolve":

        domain = None
        args = sys.argv[2:]
        
        # Parse --domain option
        if "--domain" in args:
            idx = args.index("--domain")
            if idx + 1 < len(args):
                domain = args[idx + 1]
                args = args[:idx] + args[idx + 2:]
        
        if not args:
            print("usage: fid resolve [--domain STRING] <fid> [<fid> ...]", file=sys.stderr)
            return
        resolve(args, domain=domain)

    elif cmd == "verify":

        bysize = "--bysize" in sys.argv
        prefixes = [arg for arg in sys.argv[2:] if arg != "--bysize"]
        
        if not prefixes:
            print("usage: fid verify [--bysize] <fid> [<fid> ...]", file=sys.stderr)
            return
        verify(prefixes, bysize=bysize)

    elif cmd == "meta":

        action = sys.argv[2]

        if action == "set":

            meta_set(sys.argv[3].replace("fid://", ""), sys.argv[4], sys.argv[5])

        elif action == "get":

            meta_get(sys.argv[3].replace("fid://", ""))

        elif action == "rm":

            meta_rm(sys.argv[3].replace("fid://", ""), sys.argv[4])

    elif cmd == "find":

        find(sys.argv[2])

    elif cmd == "list":

        project = None
        args = sys.argv[2:]
        
        # Parse --project option
        if "--project" in args:
            idx = args.index("--project")
            if idx + 1 < len(args):
                project = args[idx + 1]
        
        yaml_out(project=project)

    elif cmd == "clean":

        clean()

    elif cmd == "id":

        if len(sys.argv) < 3:
            print("usage: fid id <path> [<path> ...]", file=sys.stderr)
            return
        fid_id(sys.argv[2:])

    elif cmd == "purge-cache":

        purge_cache()

    elif cmd == "write":

        domain = None
        args = sys.argv[2:]
        
        # Parse --domain option
        if "--domain" in args:
            idx = args.index("--domain")
            if idx + 1 < len(args):
                domain = args[idx + 1]
                args = args[:idx] + args[idx + 2:]
        
        output_file = args[0] if len(args) > 0 else None
        write(output_file, domain=domain)

    elif cmd == "read":

        input_file = sys.argv[2] if len(sys.argv) > 2 else None
        read(input_file)

    elif cmd == "cloudpull":

        if len(sys.argv) < 3:
            print("usage: fid cloudpull <url>", file=sys.stderr)
            return
        cloudpull(sys.argv[2])

    elif cmd == "add":

        if len(sys.argv) < 4:
            print("usage: fid add <fid> <path> [<path> ...]", file=sys.stderr)
            return
        add(sys.argv[2:])

    else:

        print("unknown command")


if __name__ == "__main__":

    main()