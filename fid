############ VERIFY ####################


def verify(prefix):

    conn = db()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique")

        return

    md5_hex = matches[0][0]

    for loc_id, path in conn.execute(
        "SELECT id,path FROM locations WHERE md5_hex=?",
        (md5_hex,)
    ):

        pfx, val = split_path(path)

        if pfx != "local":
            continue

        if not os.path.exists(val):

            print("MISSING", val)

            continue

        if md5_file(val).hex() == md5_hex:

            print("OK", val)

        else:

            print("MISMATCH", val)


############ METADATA ##################


def meta_set(prefix, key, value):

    conn = db()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique")

        return

    md5_hex = matches[0][0]

    conn.execute(
        "DELETE FROM metadata WHERE md5_hex=? AND key=?",
        (md5_hex, key)
    )

    conn.execute(
        "INSERT INTO metadata VALUES(NULL,?,?,?)",
        (md5_hex, key, value)
    )

    conn.commit()


def meta_get(prefix):

    conn = db()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique")

        return

    md5_hex = matches[0][0]

    for key, value in conn.execute(
        "SELECT key,value FROM metadata WHERE md5_hex=?",
        (md5_hex,)
    ):

        print(f"{key}={value}")


def meta_rm(prefix, key):

    conn = db()

    matches = lookup(conn, prefix)

    if len(matches) != 1:

        print("prefix not unique")

        return

    md5_hex = matches[0][0]

    conn.execute(
        "DELETE FROM metadata WHERE md5_hex=? AND key=?",
        (md5_hex, key)
    )

    conn.commit()


############ FIND ######################


def find(expr):

    key, value = expr.split("=")

    conn = db()

    rows = conn.execute(
        """
        SELECT md5_base62
        FROM metadata
        JOIN files USING(md5_hex)
        WHERE key=? AND value=?
        """,
        (key, value)
    ).fetchall()

    for row in rows:

        print(row[0])


############ LIST ######################


def list_all():

    conn = db()
    cur = conn.cursor()

    files = cur.execute(
        "SELECT md5_hex, md5_base62 FROM files ORDER BY md5_base62"
    ).fetchall()

    for md5_hex, md5_b62 in files:

        print(f"fid://{md5_b62}  ({md5_hex})")

        locations = cur.execute(
            "SELECT path FROM locations WHERE md5_hex=?",
            (md5_hex,)
        ).fetchall()

        if not locations:

            print("  (no locations)")

        for (path,) in locations:

            print(f"  {path}")

        print()

############ CLI #######################


def main():

    if len(sys.argv) < 2:

        print("usage: fid <command>")

        return

    cmd = sys.argv[1]

    if cmd == "register":

        register(sys.argv[2])

    elif cmd == "resolve":

        resolve(sys.argv[2].replace("fid://", ""))

    elif cmd == "verify":

        verify(sys.argv[2].replace("fid://", ""))

    elif cmd == "meta":

        action = sys.argv[2]

        if action == "set":

            meta_set(sys.argv[3].replace("fid://", ""), sys.argv[4], sys.argv[5])

        elif action == "get":

            meta_get(sys.argv[3].replace("fid://", ""))

        elif action == "rm":

            meta_rm(sys.argv[3].replace("fid://", ""), sys.argv[4])

    elif cmd == "find":

        find(sys.argv[2])

    elif cmd == "list":

        list_all()

    elif cmd == "id":

        fid_id(sys.argv[2])

    elif cmd == "purge-cache":

        purge_cache()

    else:

        print("unknown command")


if __name__ == "__main__":

    main()